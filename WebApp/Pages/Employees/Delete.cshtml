@page "{id:int}"
@model WebApp.Pages.Employees.DeleteModel
@{
    ViewData["Title"] = "Delete Employee";
}

<h1>Delete Employee</h1>

<div class="alert alert-warning">
    <strong>Are you sure you want to delete this employee?</strong>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">SSN</dt>
            <dd class="col-sm-9">@Model.Employee.Ssn</dd>

            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Employee.FirstName @Model.Employee.LastName</dd>

            <dt class="col-sm-3">Job Title</dt>
            <dd class="col-sm-9">@Model.Employee.JobTitle</dd>

            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@Model.Employee.PhoneNo</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Employee.Email</dd>
        </dl>
    </div>
</div>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="Employee.Ssn" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>
