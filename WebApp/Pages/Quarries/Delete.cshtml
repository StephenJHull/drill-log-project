@page "{id}"
@model WebApp.Pages.Quarries.DeleteModel
@{
    ViewData["Title"] = "Delete Quarry";
}

<h1>Delete Quarry</h1>

<div class="alert alert-warning">
    <strong>Are you sure you want to delete this quarry?</strong>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Quarry.Name</dd>

            <dt class="col-sm-3">Location</dt>
            <dd class="col-sm-9">@Model.Quarry.Location</dd>

            <dt class="col-sm-3">Company</dt>
            <dd class="col-sm-9">@Model.Quarry.Company</dd>

            <dt class="col-sm-3">Rock Type</dt>
            <dd class="col-sm-9">@Model.Quarry.RockType</dd>

            <dt class="col-sm-3">Annual Production</dt>
            <dd class="col-sm-9">@(Model.Quarry.AnnualProduction?.ToString("N0")) tons</dd>
        </dl>
    </div>
</div>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="Quarry.Name" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>
