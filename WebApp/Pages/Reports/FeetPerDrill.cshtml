@page
@model WebApp.Pages.Reports.FeetPerDrillModel
@{
    ViewData["Title"] = "Feet Drilled per Drill";
}

<h1>Feet Drilled per Drill (Last Year)</h1>

<p class="text-muted">
    Reporting window: <strong>@Model.ReportStartDate.ToString("yyyy-MM-dd")</strong> to <strong>@Model.ReportEndDate.ToString("yyyy-MM-dd")</strong>
</p>

@if (Model.DrillFeetStats.Count == 0)
{
    <div class="alert alert-info">No drilling hole records were found for the selected date range.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Machine ID</th>
                <th>Model</th>
                <th>Holes Drilled</th>
                <th>Total Feet Drilled</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var stat in Model.DrillFeetStats)
            {
                <tr>
                    <td>@stat.MachineId</td>
                    <td>@stat.ModelName</td>
                    <td>@stat.HolesDrilled</td>
                    <td>@stat.TotalFeetDrilled.ToString("N0")</td>
                </tr>
            }
        </tbody>
    </table>
}
