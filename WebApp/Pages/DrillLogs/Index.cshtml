@page
@model WebApp.Pages.DrillLogs.IndexModel
@{
    ViewData["Title"] = "Drill Logs";
}

<h1>Drill Logs</h1>

@if (User.IsInRole("Admin") || User.IsInRole("Driller") || User.IsInRole("Blaster"))
{
    <p>
        <a asp-page="Create" class="btn btn-success">Create New Drill Log</a>
        <a asp-page="NewDrillLog" class="btn btn-primary ms-2">New Complete Drill Log</a>
    </p>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Shot ID</th>
            <th>Quarry</th>
            <th>Driller</th>
            <th>Time Began</th>
            <th>Last Saved</th>
            <th>Submitted</th>
            @if (User.IsInRole("Admin") || User.IsInRole("Driller") || User.IsInRole("Blaster"))
            {
                <th>Actions</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model.DrillLogs)
        {
            <tr>
                <td>@log.ShotId</td>
                <td>@log.QuarryName</td>
                <td>@log.DrillerSsnNavigation?.FirstName @log.DrillerSsnNavigation?.LastName</td>
                <td>@log.TimeBegan.ToString("g")</td>
                <td>@log.TimeLastSaved?.ToString("g")</td>
                <td>@log.TimeSubmitted?.ToString("g")</td>
                @if (User.IsInRole("Admin") || User.IsInRole("Driller") || User.IsInRole("Blaster"))
                {
                    <td>
                        <a asp-page="Edit" asp-route-id="@log.ShotId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-page="Delete" asp-route-id="@log.ShotId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>
