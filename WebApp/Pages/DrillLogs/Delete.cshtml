@page "{id:int}"
@model WebApp.Pages.DrillLogs.DeleteModel
@{
    ViewData["Title"] = "Delete Drill Log";
}

<h1>Delete Drill Log</h1>

<div class="alert alert-warning">
    <strong>Are you sure you want to delete this drill log?</strong>
    <br/>This will also affect any associated drill holes and patterns.
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Shot ID</dt>
            <dd class="col-sm-9">@Model.DrillLog.ShotId</dd>

            <dt class="col-sm-3">Quarry</dt>
            <dd class="col-sm-9">@Model.DrillLog.QuarryName</dd>

            <dt class="col-sm-3">Driller</dt>
            <dd class="col-sm-9">@Model.DrillLog.DrillerSsnNavigation?.FirstName @Model.DrillLog.DrillerSsnNavigation?.LastName</dd>

            <dt class="col-sm-3">Time Began</dt>
            <dd class="col-sm-9">@Model.DrillLog.TimeBegan.ToString("g")</dd>

            <dt class="col-sm-3">Submitted</dt>
            <dd class="col-sm-9">@Model.DrillLog.TimeSubmitted?.ToString("g")</dd>
        </dl>
    </div>
</div>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="DrillLog.ShotId" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>
