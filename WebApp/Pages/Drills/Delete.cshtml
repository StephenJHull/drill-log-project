@page "{id:int}"
@model WebApp.Pages.Drills.DeleteModel
@{
    ViewData["Title"] = "Delete Drill";
}

<h1>Delete Drill</h1>

<div class="alert alert-warning">
    <strong>Are you sure you want to delete this drill?</strong>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Machine ID</dt>
            <dd class="col-sm-9">@Model.Drill.MachineId</dd>

            <dt class="col-sm-3">Model</dt>
            <dd class="col-sm-9">@Model.Drill.ModelName</dd>

            <dt class="col-sm-3">Manufacturer</dt>
            <dd class="col-sm-9">@Model.Drill.ModelNameNavigation?.Manufacture</dd>

            <dt class="col-sm-3">Age</dt>
            <dd class="col-sm-9">@Model.Drill.Age years</dd>

            <dt class="col-sm-3">Total Hours</dt>
            <dd class="col-sm-9">@Model.Drill.TotalHours.ToString("N0")</dd>

            <dt class="col-sm-3">Rebuilds</dt>
            <dd class="col-sm-9">@Model.Drill.Rebuilts</dd>
        </dl>
    </div>
</div>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="Drill.MachineId" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>
